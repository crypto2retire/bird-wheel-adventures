{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile"
  },
  "deploy": {
    "startCommand": "node server.js",
    "startCommand": "npx vite preview --host --port $PORT",
    "healthcheckPath": "/",
    "restartPolicyType": "on-failure",
    "restartPolicyMaxRetries": 3
  }
}
